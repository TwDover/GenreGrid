{
  "id": "latin_jazz",
  "name": "Latin Jazz",
  "bpm_range": [120, 200],
  "default_scale": "major",
  "preferred_keys": ["C", "F", "Bb", "Eb", "G", "D"],
  "progression_templates": [
    ["ii", "V", "I", "vi"],
    ["I", "vi", "ii", "V"],
    ["iii", "VI", "ii", "V"]
  ],
  "chord_extensions": {
    "allow_7th": 1.0,
    "allow_9th": 0.75
  },
  "bass": {
    "pattern_density": 0.8,
    "octave_jumps": 0.2,
    "sustain_bias": 0.2
  },
  "melody": {
    "density": 0.6,
    "stepwise_motion": 0.5,
    "leap_probability": 0.35,
    "rest_probability": 0.15,
    "range": [60, 84]
  },
  "drums": {
    "hat_density": 0.75,
    "triplet_probability": 0.6,
    "snare_standard_beats": [2, 4],
    "swing": 0.55,
    "use_ride": true,
    "tom_fills": true
  }
}
