{
  "id": "future_bass",
  "name": "Future Bass",
  "bpm_range": [140, 160],
  "default_scale": "major",
  "preferred_keys": ["C", "D", "F", "G", "A"],
  "progression_templates": [
    ["I", "vi", "IV", "V"],
    ["I", "V", "vi", "IV"],
    ["vi", "IV", "I", "V"]
  ],
  "chord_extensions": {
    "allow_7th": 0.85,
    "allow_9th": 0.65
  },
  "bass": {
    "pattern_density": 0.7,
    "octave_jumps": 0.3,
    "sustain_bias": 0.3
  },
  "melody": {
    "density": 0.65,
    "stepwise_motion": 0.55,
    "leap_probability": 0.3,
    "rest_probability": 0.15,
    "range": [64, 88]
  },
  "drums": {
    "hat_density": 0.8,
    "triplet_probability": 0.25,
    "snare_standard_beats": [2, 4],
    "swing": 0.1,
    "use_clap": true,
    "crash_on_bar_1": true
  }
}
