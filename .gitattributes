# Line-ending policy: LF everywhere, in the repo AND the working copy.
# This overrides core.autocrlf, which was converting files on checkout and
# warning on every `git add` of a newly created LF file. All modern Windows
# tooling (VS Code, Python, Node, Git Bash) handles LF natively.
* text=auto eol=lf

# PowerShell scripts are the one exception — CRLF on Windows.
*.ps1  text eol=crlf

# Binary assets — never touch line endings.
*.mid  binary
*.png  binary
*.ico  binary
*.icns binary
