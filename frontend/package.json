{
  "name": "genregrid-frontend",
  "private": true,
  "version": "0.1.0",
  "license": "GPL-3.0-only",
  "description": "Genregrid — A Midi Loop Generator",
  "author": {
    "name": "TwDover",
    "email": "twdover@gmail.com"
  },
  "homepage": "https://github.com/TwDover/GenreGrid",
  "repository": {
    "type": "git",
    "url": "https://github.com/TwDover/GenreGrid.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "dev:electron": "vite --config vite.electron.config.ts",
    "build:electron": "vue-tsc --noEmit && vite build --config vite.electron.config.ts && electron-builder"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "tone": "^15.1.22",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.4.0",
    "vite": "^8.1.3",
    "vite-plugin-electron": "^1.1.0",
    "vue-tsc": "^2.0.0"
  },
  "build": {
    "appId": "com.genregrid.app",
    "productName": "GenreGrid",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon.png",
      "category": "AudioVideo"
    },
    "extraResources": [
      {
        "from": "../backend/dist/genregrid-backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
