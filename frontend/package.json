{
  "name": "genregrid-frontend",
  "private": true,
  "version": "0.1.0",
  "license": "GPL-3.0-only",
  "description": "Genregrid — A Midi Loop Generator",
  "author": {
    "name": "TwDover",
    "email": "twdover@gmail.com"
  },
  "homepage": "https://github.com/TwDover/GenreGrid",
  "repository": {
    "type": "git",
    "url": "https://github.com/TwDover/GenreGrid.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "preview": "vite preview",
    "dev:electron": "vite --config vite.electron.config.ts",
    "build:electron": "vue-tsc --noEmit && vite build --config vite.electron.config.ts && electron-builder --publish never"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "electron-updater": "^6.8.9",
    "tone": "^15.1.22",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.10.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.3",
    "vite-plugin-electron": "^1.1.0",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.0.0"
  },
  "build": {
    "appId": "com.genregrid.app",
    "productName": "GenreGrid",
    "publish": {
      "provider": "github",
      "owner": "TwDover",
      "repo": "GenreGrid"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon.png",
      "category": "public.app-category.music",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon.png",
      "category": "AudioVideo"
    },
    "extraResources": [
      {
        "from": "../backend/dist/genregrid-backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
